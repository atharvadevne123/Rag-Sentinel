# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Database — SQLite for dev, PostgreSQL for prod
DATABASE_URL=sqlite:///./rag_sentinel.db
# DATABASE_URL=postgresql://sentinel:sentinel@db:5432/rag_sentinel

# Model artefacts
MODEL_PATH=model.joblib
METRICS_PATH=metrics.json

# RAG index
FAISS_INDEX_PATH=rag_index.faiss
CHUNK_SIZE=128
CHUNK_OVERLAP=16

# Drift detection
DRIFT_WINDOW_HOURS=24
DRIFT_P_THRESHOLD=0.05

# Postgres (docker-compose)
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
POSTGRES_DB=rag_sentinel
